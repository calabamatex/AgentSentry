{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "bash agent-sentry/scripts/session-start-checks.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash agent-sentry/scripts/context-estimator.sh",
            "timeout": 5000
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash agent-sentry/scripts/context-critical-stop.sh",
            "timeout": 5000
          }
        ]
      }
    ]
  }
}
